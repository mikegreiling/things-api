{
  "id": "reads-inbox-count",
  "family": "reads",
  "tier": 1,
  "split": "dev",
  "prompt": "I have a feeling I already captured something about calling a plumber, but I can't remember where I put it. Is there anything like that sitting in my Inbox? Answer with a JSON object of the form {\"found\": true|false, \"title\": \"<the exact to-do title, or empty string>\"}.",
  "clock": { "now": "2026-03-15T09:00:00-05:00", "tz": "America/Chicago" },
  "seed": [
    { "kind": "area", "key": "errands", "title": "Errands" },
    { "kind": "todo", "key": "i1", "title": "Buy stamps", "start": "inbox" },
    { "kind": "todo", "key": "i2", "title": "Call the plumber", "start": "inbox" },
    { "kind": "todo", "key": "i3", "title": "Return the library book", "start": "inbox" },
    {
      "kind": "todo",
      "key": "a1",
      "title": "Plan the weekend trip",
      "start": "active",
      "container": "errands"
    }
  ],
  "finalAnswer": { "required": true, "shape": "{ found: boolean, title: string }" },
  "assertions": [
    { "type": "answer", "path": "found", "equals": true },
    { "type": "answer", "path": "title", "equals": "Call the plumber" },
    { "type": "db-unchanged" },
    {
      "type": "sql",
      "query": "SELECT COUNT(*) AS n FROM TMTask WHERE type = 0 AND status = 0 AND trashed = 0 AND start = 0 AND title = 'Call the plumber'",
      "expect": [{ "n": 1 }]
    }
  ],
  "maxTurns": 12,
  "timeoutMs": 60000,
  "pseudoScript": ["things inbox --json"]
}
