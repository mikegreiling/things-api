{
  "suite": "u",
  "description": "URL-scheme re-validation: T01–T20 findings from docs/research/validation-notes-step3.md re-encoded as instrumented probes. Canonical transport is `open -g` (background-open) except U01, which deliberately re-tests plain-open launch/foreground behavior. U10/U11/U15 are discovery cells (T10 never ran; T11/T15 were evidence-based); their expectations were locked from the first observed run. Hazard-group probes run last.",
  "probes": [
    {
      "id": "U01",
      "legacyRef": "T01",
      "title": "version command launches Things and steals focus (plain open)",
      "vector": "url",
      "operation": "app.version-probe",
      "appState": "not-running",
      "commands": [{ "openUrl": "things:///version", "foreground": true }, { "sleep": 5 }],
      "settleSeconds": 3,
      "expect": {
        "verdict": "supported",
        "tier": 2,
        "assertions": [{ "kind": "deltaEmpty" }]
      }
    },
    {
      "id": "U02",
      "legacyRef": "T02",
      "title": "update without auth-token: modal error, no mutation",
      "vector": "url",
      "operation": "todo.update-unauthenticated",
      "appState": "running-background",
      "setup": [
        { "openUrl": "things:///add?title=U02-TARGET&when=anytime" },
        { "waitSql": "SELECT uuid FROM TMTask WHERE title='U02-TARGET'" }
      ],
      "commands": [{ "openUrl": "things:///update?id={uuid:U02-TARGET}&title=U02-RENAMED" }],
      "settleSeconds": 4,
      "cleanup": [{ "exec": ["pkill", "-x", "Things3"] }],
      "expect": {
        "verdict": "unsupported",
        "tier": 3,
        "assertions": [
          {
            "kind": "fieldUnchanged",
            "table": "TMTask",
            "where": { "title": "U02-TARGET" },
            "fields": ["title", "status", "notes"]
          },
          { "kind": "rowAbsent", "table": "TMTask", "where": { "title": "U02-RENAMED" } }
        ]
      }
    },
    {
      "id": "U03",
      "legacyRef": "T03",
      "title": "add with unknown tag: to-do created, tag silently ignored",
      "vector": "url",
      "operation": "todo.create",
      "appState": "running-background",
      "commands": [
        { "openUrl": "things:///add?title=U03-TagProbe&tags=U03-NoSuchTag" },
        { "waitSql": "SELECT uuid FROM TMTask WHERE title='U03-TagProbe'" }
      ],
      "expect": {
        "verdict": "supported",
        "tier": 0,
        "assertions": [
          { "kind": "inserted", "table": "TMTask", "where": { "title": "U03-TagProbe" } },
          {
            "kind": "fieldEquals",
            "table": "TMTask",
            "where": { "title": "U03-TagProbe" },
            "field": "start",
            "value": 0
          },
          { "kind": "rowAbsent", "table": "TMTag", "where": { "title": "U03-NoSuchTag" } },
          {
            "kind": "rowCount",
            "table": "TMTaskTag",
            "where": { "tasks": "@uuidOf:TMTask:title=U03-TagProbe" },
            "count": 0
          }
        ]
      }
    },
    {
      "id": "U04",
      "legacyRef": "T04",
      "title": "tags param is full-set replacement; matching is case-insensitive",
      "vector": "url",
      "operation": "todo.tags-replace",
      "appState": "running-background",
      "setup": [
        { "openUrl": "things:///add?title=U04-TARGET&when=anytime" },
        { "waitSql": "SELECT uuid FROM TMTask WHERE title='U04-TARGET'" }
      ],
      "commands": [
        {
          "openUrl": "things:///update?id={uuid:U04-TARGET}&auth-token={ctx:token}&tags=lab-tag-1,lab-tag-2"
        },
        {
          "waitSql": "SELECT 1 FROM TMTaskTag tt JOIN TMTag t ON tt.tags=t.uuid WHERE tt.tasks='{uuid:U04-TARGET}' AND t.title='lab-tag-2'"
        },
        {
          "openUrl": "things:///update?id={uuid:U04-TARGET}&auth-token={ctx:token}&tags=LAB-TAG-1"
        },
        {
          "waitSql": "SELECT 1 WHERE NOT EXISTS (SELECT 1 FROM TMTaskTag tt JOIN TMTag t ON tt.tags=t.uuid WHERE tt.tasks='{uuid:U04-TARGET}' AND t.title='lab-tag-2')"
        }
      ],
      "expect": {
        "verdict": "supported",
        "tier": 0,
        "assertions": [
          {
            "kind": "rowCount",
            "table": "TMTaskTag",
            "where": { "tasks": "@uuidOf:TMTask:title=U04-TARGET" },
            "count": 1
          },
          {
            "kind": "rowExists",
            "table": "TMTaskTag",
            "where": { "tasks": "@uuidOf:TMTask:title=U04-TARGET", "tags": "@seed:lab-tag-1" }
          },
          { "kind": "rowAbsent", "table": "TMTag", "where": { "title": "LAB-TAG-1" } }
        ]
      }
    },
    {
      "id": "U05",
      "legacyRef": "T05",
      "title": "add-area is not a URL command: modal error, no area created",
      "vector": "url",
      "operation": "area.create",
      "appState": "running-background",
      "commands": [{ "openUrl": "things:///add-area?title=U05-ShouldFail" }],
      "settleSeconds": 4,
      "cleanup": [{ "exec": ["pkill", "-x", "Things3"] }],
      "expect": {
        "verdict": "unsupported",
        "tier": 3,
        "assertions": [
          { "kind": "rowAbsent", "table": "TMArea", "where": { "title": "U05-ShouldFail" } },
          { "kind": "notInserted", "table": "TMArea" }
        ]
      }
    },
    {
      "id": "U06",
      "legacyRef": "T06",
      "title": "update list=<unknown area>: silent no-op",
      "vector": "url",
      "operation": "todo.move-to-area",
      "appState": "running-background",
      "setup": [
        { "openUrl": "things:///add?title=U06-TARGET&when=today" },
        { "waitSql": "SELECT uuid FROM TMTask WHERE title='U06-TARGET'" }
      ],
      "commands": [
        {
          "openUrl": "things:///update?id={uuid:U06-TARGET}&auth-token={ctx:token}&list=U06-NoSuchArea"
        },
        { "sleep": 3 }
      ],
      "expect": {
        "verdict": "silent-noop",
        "tier": 0,
        "assertions": [
          {
            "kind": "fieldUnchanged",
            "table": "TMTask",
            "where": { "title": "U06-TARGET" },
            "fields": ["area", "project", "start", "startDate"]
          },
          {
            "kind": "fieldEquals",
            "table": "TMTask",
            "where": { "title": "U06-TARGET" },
            "field": "area",
            "value": null
          }
        ]
      }
    },
    {
      "id": "U06B",
      "legacyRef": "T06",
      "title": "update list=<existing area, case-insensitive>: moves, preserves when",
      "vector": "url",
      "operation": "todo.move-to-area",
      "appState": "running-background",
      "commands": [
        {
          "openUrl": "things:///update?id={uuid:U06-TARGET}&auth-token={ctx:token}&list=lab-area-a"
        },
        { "waitSql": "SELECT 1 FROM TMTask WHERE title='U06-TARGET' AND area='{seed:LAB-AREA-A}'" }
      ],
      "expect": {
        "verdict": "supported",
        "tier": 0,
        "assertions": [
          {
            "kind": "fieldEquals",
            "table": "TMTask",
            "where": { "title": "U06-TARGET" },
            "field": "area",
            "value": "@seed:LAB-AREA-A"
          },
          {
            "kind": "fieldEquals",
            "table": "TMTask",
            "where": { "title": "U06-TARGET" },
            "field": "start",
            "value": 1
          },
          {
            "kind": "fieldUnchanged",
            "table": "TMTask",
            "where": { "title": "U06-TARGET" },
            "fields": ["startDate"]
          }
        ]
      }
    },
    {
      "id": "U07",
      "legacyRef": "T07",
      "title": "checklist-items is wholesale replacement (destructive to item state)",
      "vector": "url",
      "operation": "todo.checklist-replace",
      "appState": "running-background",
      "setup": [
        {
          "openUrl": "things:///add?title=U07-TARGET&when=anytime&checklist-items=Alpha%0ABravo%0ACharlie"
        },
        {
          "waitSql": "SELECT 1 WHERE (SELECT COUNT(*) FROM TMChecklistItem WHERE task='{uuid:U07-TARGET}')=3"
        }
      ],
      "commands": [
        {
          "openUrl": "things:///update?id={uuid:U07-TARGET}&auth-token={ctx:token}&checklist-items=Delta%0AEcho"
        },
        {
          "waitSql": "SELECT 1 WHERE (SELECT COUNT(*) FROM TMChecklistItem WHERE task='{uuid:U07-TARGET}')=2"
        }
      ],
      "expect": {
        "verdict": "supported",
        "tier": 0,
        "assertions": [
          {
            "kind": "rowCount",
            "table": "TMChecklistItem",
            "where": { "task": "@uuidOf:TMTask:title=U07-TARGET" },
            "count": 2
          },
          {
            "kind": "rowExists",
            "table": "TMChecklistItem",
            "where": { "task": "@uuidOf:TMTask:title=U07-TARGET", "title": "Delta" }
          },
          {
            "kind": "rowAbsent",
            "table": "TMChecklistItem",
            "where": { "task": "@uuidOf:TMTask:title=U07-TARGET", "title": "Alpha" }
          },
          {
            "kind": "fieldUnchanged",
            "table": "TMTask",
            "where": { "title": "U07-TARGET" },
            "fields": ["title", "notes", "status", "start"]
          }
        ]
      }
    },
    {
      "id": "U08",
      "legacyRef": "T08",
      "title": "project completion auto-completes open children, no prompt (unlike UI)",
      "vector": "url",
      "operation": "project.complete",
      "appState": "running-background",
      "setup": [
        { "openUrl": "things:///add-project?title=U08-PROJ&to-dos=U08-C1%0AU08-C2" },
        { "waitSql": "SELECT uuid FROM TMTask WHERE title='U08-C2'" },
        { "openUrl": "things:///update?id={uuid:U08-C2}&auth-token={ctx:token}&canceled=true" },
        { "waitSql": "SELECT 1 FROM TMTask WHERE title='U08-C2' AND status=2" }
      ],
      "commands": [
        {
          "openUrl": "things:///update-project?id={uuid:U08-PROJ}&auth-token={ctx:token}&completed=true"
        },
        { "waitSql": "SELECT 1 FROM TMTask WHERE title='U08-PROJ' AND status=3" }
      ],
      "expect": {
        "verdict": "supported",
        "tier": 0,
        "assertions": [
          {
            "kind": "fieldEquals",
            "table": "TMTask",
            "where": { "title": "U08-PROJ" },
            "field": "status",
            "value": 3
          },
          {
            "kind": "fieldEquals",
            "table": "TMTask",
            "where": { "title": "U08-C1" },
            "field": "status",
            "value": 3
          },
          {
            "kind": "fieldEquals",
            "table": "TMTask",
            "where": { "title": "U08-C2" },
            "field": "status",
            "value": 2
          }
        ]
      }
    },
    {
      "id": "U09",
      "legacyRef": "T09",
      "title": "heading= on add does not create a missing heading (placement-only param)",
