        "tier": 0,
        "assertions": [
          { "kind": "inserted", "table": "TMTask", "where": { "title": "U09-HeadProbe" } },
          {
            "kind": "fieldEquals",
            "table": "TMTask",
            "where": { "title": "U09-HeadProbe" },
            "field": "project",
            "value": "@seed:LAB-PROJ-PLAIN"
          },
          {
            "kind": "fieldEquals",
            "table": "TMTask",
            "where": { "title": "U09-HeadProbe" },
            "field": "heading",
            "value": null
          },
          { "kind": "rowAbsent", "table": "TMTask", "where": { "title": "U09-NoSuchHeading" } }
        ]
      }
    },
    {
