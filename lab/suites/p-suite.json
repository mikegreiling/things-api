          },
          {
            "kind": "fieldEquals",
            "table": "TMTask",
            "where": {
              "title": "P-RO-2"
            },
            "field": "status",
            "value": 3
          }
        ]
      }
    },
    {
      "id": "P03",
      "title": "cascade stopDate timing: completing a project stamps children within <2s of the project row (heuristic window for detecting cascaded children)",
      "vector": "url",
      "operation": "project.cascade-timing",
      "appState": "running-background",
      "setup": [
        {
          "openUrl": "things:///add-project?title=P-TIMING&to-dos=P-TM-1"
        },
        {
          "waitSql": "SELECT uuid FROM TMTask WHERE title='P-TIMING' AND type=1"
        }
      ],
      "commands": [
        {
          "openUrl": "things:///update-project?id={uuid:P-TIMING}&auth-token={ctx:token}&completed=true"
        },
        {
          "waitSql": "SELECT 1 FROM TMTask p, TMTask c WHERE p.title='P-TIMING' AND c.title='P-TM-1' AND p.status=3 AND c.status=3 AND abs(p.stopDate - c.stopDate) < 2",
          "timeoutSeconds": 10
        }
      ],
      "expect": {
        "verdict": "supported",
        "tier": 0,
        "assertions": [
          {
            "kind": "fieldEquals",
            "table": "TMTask",
            "where": {
              "title": "P-TIMING"
            },
            "field": "status",
            "value": 3
          },
          {
            "kind": "fieldEquals",
            "table": "TMTask",
            "where": {
              "title": "P-TM-1"
            },
            "field": "status",
            "value": 3
          }
        ]
      }
    },
