{
  "suite": "p",
  "description": "Gap-closure campaign (Phase 18, 2026-07-06): project cancel/reopen + cascade semantics and stopDate timing (undo heuristic), trashed-project restore candidates, project/to-do area removal, container-clear + schedule/deadline survival, empty tag/checklist replacement, parent-tag deletion orphan behavior, top-level project ordering, and the json checklist-states unlock (hazard-quarantined). Expectations are DISCOVERY GUESSES until the first run locks them. EXTENDED 2026-07-06b: sidebar-order read oracle, ephemeral-area chain, URL empty list-id/area-id container clears, update-project?area-id move, AppleScript empty-string nil, json-null container clears (hazard). EXTENDED 2026-07-06c: P28-P30 \u2014 the last tag-un-parent stones (empty-string nil, delete-property, move verb; tags have no URL/json surface, so AppleScript spellings are the only remaining candidates).",
  "probes": [
    {
      "id": "P01",
      "title": "project cancel via update-project?canceled=true \u2014 does it cascade like complete (T08/U08 analog)? mixed statuses: open child + already-completed child",
      "vector": "url",
      "operation": "project.cancel",
      "appState": "running-background",
      "setup": [
        {
          "openUrl": "things:///add-project?title=P-CANCEL&to-dos=P-CN-OPEN%0AP-CN-DONE"
        },
        {
          "waitSql": "SELECT uuid FROM TMTask WHERE title='P-CANCEL' AND type=1"
        },
        {
          "openUrl": "things:///update?id={uuid:P-CN-DONE}&auth-token={ctx:token}&completed=true"
        },
        {
          "waitSql": "SELECT 1 FROM TMTask WHERE title='P-CN-DONE' AND status=3"
        }
      ],
      "commands": [
        {
          "openUrl": "things:///update-project?id={uuid:P-CANCEL}&auth-token={ctx:token}&canceled=true"
        },
        {
          "waitSql": "SELECT 1 FROM TMTask WHERE title='P-CANCEL' AND status=2",
          "timeoutSeconds": 10
        }
      ],
      "expect": {
        "verdict": "supported",
        "tier": 0,
        "assertions": [
          {
            "kind": "fieldEquals",
            "table": "TMTask",
            "where": {
              "title": "P-CANCEL"
            },
            "field": "status",
            "value": 2
          },
          {
            "kind": "fieldEquals",
            "table": "TMTask",
            "where": {
              "title": "P-CN-OPEN"
            },
            "field": "status",
            "value": 2
          },
          {
            "kind": "fieldUnchanged",
            "table": "TMTask",
            "where": {
              "title": "P-CN-DONE"
            },
            "fields": ["status", "stopDate"]
          }
        ]
      }
    },
