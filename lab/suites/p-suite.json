        },
        {
          "waitSql": "SELECT 1 FROM TMTask WHERE title='P-REOPEN' AND status=0",
          "timeoutSeconds": 10
        }
      ],
      "expect": {
        "verdict": "supported",
        "tier": 0,
        "assertions": [
          {
            "kind": "fieldEquals",
