    {
      "id": "P16",
      "title": "delete a PARENT tag: the child tag is CASCADE-DELETED with it (subtree destruction \u2014 un-nest-via-scratch-parent is dead; tag.delete needs a children hazard)",
      "vector": "applescript",
      "operation": "tag.parent-delete-orphan",
      "appState": "running-background",
      "setup": [
        {
          "osascript": "tell application \"Things3\" to make new tag with properties {name:\"P-TAG-PARENT\"}"
        },
        {
          "osascript": "tell application \"Things3\" to make new tag with properties {name:\"P-TAG-CHILD\"}"
        },
        {
          "osascript": "tell application \"Things3\" to set parent tag of tag \"P-TAG-CHILD\" to tag \"P-TAG-PARENT\""
        },
        {
          "waitSql": "SELECT 1 FROM TMTag c JOIN TMTag p ON c.parent=p.uuid WHERE c.title='P-TAG-CHILD' AND p.title='P-TAG-PARENT'"
        }
      ],
      "commands": [
        {
          "osascript": "tell application \"Things3\" to delete tag \"P-TAG-PARENT\""
        },
        {
          "waitSql": "SELECT 1 WHERE NOT EXISTS (SELECT 1 FROM TMTag WHERE title='P-TAG-PARENT')",
          "timeoutSeconds": 8
        }
      ],
      "expect": {
        "verdict": "supported",
        "tier": 0,
        "assertions": [
