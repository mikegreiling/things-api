{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "options": {
    "denyWarnings": true,
    "reportUnusedDisableDirectives": "error"
  },
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "rules": {
    "no-await-in-loop": "off"
  },
  "env": {
    "builtin": true
  },
  "ignorePatterns": ["dist", "coverage", "lab/artifacts", ".claude"]
}
